{
  "name": "@we/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/infrastructure/db/migrate.ts",
    "db:seed": "bun run src/infrastructure/db/seed.ts",
    "db:reset": "bun run src/infrastructure/db/reset.ts"
  },
  "dependencies": {
    "@we/shared": "workspace:*",
    "elysia": "^1.1.25",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/swagger": "^1.1.6",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "bun-types": "^1.1.34",
    "typescript": "^5.6.3"
  }
}
